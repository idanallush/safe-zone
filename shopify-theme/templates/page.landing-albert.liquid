<script>
(function() {
    'use strict';

    /* ========================================
       UTM PARAMETER EXTRACTION
    ======================================== */
    var urlParams = new URLSearchParams(window.location.search);
    var utmData = {
        utm_source: urlParams.get('utm_source') || '',
        utm_medium: urlParams.get('utm_medium') || '',
        utm_campaign: urlParams.get('utm_campaign') || '',
        utm_content: urlParams.get('utm_content') || ''
    };

    /* Populate hidden UTM fields in all forms */
    document.querySelectorAll('.inquiry-form').forEach(function(form) {
        Object.keys(utmData).forEach(function(key) {
            var input = form.querySelector('input[name="' + key + '"]');
            if (input) input.value = utmData[key];
        });
    });

    /* ========================================
       GOOGLE SHEETS SUBMISSION
    ======================================== */
    var SHEETS_URL = 'https://script.google.com/macros/s/AKfycbxdWAO3hT5J4t7TubgEQFmEK07c3Vqm6Ywf4IW-rScHcOyem5S3S4HhbE3FTQLKwxe0/exec';

    function submitToSheets(form, callback) {
        var formLocation = form.getAttribute('data-form-location') || 'bottom';
        var artworkSelect = form.querySelector('select[name="artwork"]');
        var budgetSelect = form.querySelector('select[name="budget"]');

        var payload = {
            timestamp: new Date().toISOString(),
            first_name: form.querySelector('input[name="firstName"]').value.trim(),
            email: form.querySelector('input[name="email"]').value.trim(),
            phone: form.querySelector('input[name="phone"]').value.trim(),
            budget: budgetSelect ? budgetSelect.value : '',
            artwork: artworkSelect ? artworkSelect.value : '',
            message: form.querySelector('textarea[name="message"]').value.trim(),
            status: 'ליד חדש',
            utm_source: utmData.utm_source,
            utm_medium: utmData.utm_medium,
            utm_campaign: utmData.utm_campaign,
            utm_content: utmData.utm_content,
            form_location: formLocation,
            page_version: 'v1'
        };

        fetch(SHEETS_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(function() {
            /* no-cors returns opaque response, treat as success */
            callback(null, payload);
        })
        .catch(function(err) {
            callback(err, payload);
        });
    }

    /* ========================================
       TRACKING EVENTS (fired after successful submit)
    ======================================== */
    function fireLeadEvents(artworkName, formLocation, budgetRange) {
        /* Facebook Pixel Lead event */
        if (typeof fbq === 'function') {
            fbq('track', 'Lead', {
                content_name: artworkName,
                content_category: 'original_artwork',
                value: 0,
                currency: 'USD'
            });
        }

        /* GA4 generate_lead event */
        if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', {
                event_category: 'form',
                event_label: artworkName,
                form_location: formLocation,
                budget_range: budgetRange,
                currency: 'USD'
            });
        }
    }

    /* ========================================
       ARTWORK DATA FOR CUSTOM DROPDOWN
    ======================================== */
    var artworks = [
        { name: 'Am Yisrael Chai - Tree Of Life', img: '{{ "am-yisrael-chai.jpg" | file_url }}' },
        { name: 'Lion of Judah', img: '{{ "lion-of-judah.jpg" | file_url }}' },
        { name: 'We Will Dance Again', img: '{{ "we-will-dance-again.jpg" | file_url }}' },
        { name: 'Map Of Israel', img: '{{ "map-of-israel.jpg" | file_url }}' },
        { name: 'Heart of Protection', img: '{{ "heart-of-protection.jpg" | file_url }}' },
        { name: 'Jerusalem - Home of My Heart', img: '{{ "jerusalem.jpg" | file_url }}' },
        { name: 'Hamsa', img: '{{ "hamsa-eye.jpg" | file_url }}' },
        { name: 'Strong Together', img: '{{ "flag-of-israel.jpg" | file_url }}' },
        { name: 'Peace Will Return', img: '{{ "blue-bird.jpg" | file_url }}' },
        { name: 'Everlasting Love', img: '{{ "lion-family.jpg" | file_url }}' },
        { name: 'Tree Of Life - Earth', img: '{{ "tree-of-life-earth.jpg" | file_url }}' },
        { name: 'Tree Of Life - Colorful Dream', img: '{{ "tree-of-life-colorful.jpg" | file_url }}' },
        { name: 'Light of Hope', img: '{{ "hamsa.jpg" | file_url }}' },
        { name: 'Menorah', img: '{{ "menorah.jpg" | file_url }}' },
        { name: 'Together We Win', img: '{{ "together-we-win.jpg" | file_url }}' },
        { name: 'Blue Life', img: 'https://www.albertlevi.com/cdn/shop/files/710d0ce242761340f3794a1d9e8271b9.jpg?width=100' },
        { name: 'Colorful Life', img: 'https://www.albertlevi.com/cdn/shop/files/10.jpg?width=100' },
        { name: 'Roar Of Strength', img: 'https://www.albertlevi.com/cdn/shop/files/9.jpg?width=100' },
        { name: 'Our Connection', img: 'https://www.albertlevi.com/cdn/shop/files/6.jpg?width=100' },
        { name: 'Proud Of Us', img: 'https://www.albertlevi.com/cdn/shop/files/12_b9ec4321-a1ef-4621-b670-7f06d9d3d311.jpg?width=100' },
        { name: 'Other / Custom Commission', img: null }
    ];

    /* ========================================
       BUILD CUSTOM ARTWORK DROPDOWNS
    ======================================== */
    document.querySelectorAll('.artwork-select-wrap').forEach(function(wrap) {
        var trigger = wrap.querySelector('.artwork-select-trigger');
        var dropdown = wrap.querySelector('.artwork-dropdown');
        var hiddenSelect = wrap.querySelector('select');

        var defaultOpt = document.createElement('option');
        defaultOpt.value = ''; defaultOpt.disabled = true; defaultOpt.selected = true;
        defaultOpt.textContent = 'Which artwork interests you?';
        hiddenSelect.appendChild(defaultOpt);

        artworks.forEach(function(art, i) {
            var opt = document.createElement('option');
            opt.value = art.name; opt.textContent = art.name;
            hiddenSelect.appendChild(opt);

            var div = document.createElement('div');
            div.className = 'artwork-option';
            div.setAttribute('data-value', art.name);
            div.setAttribute('data-index', i + 1);
            div.setAttribute('role', 'option');

            if (art.img) {
                div.innerHTML = '<img src="' + art.img + '" alt="' + art.name + '" loading="lazy"><span>' + art.name + '</span>';
            } else {
                div.innerHTML = '<span class="no-img">&#9998;</span><span>' + art.name + '</span>';
            }

            div.addEventListener('click', function() {
                hiddenSelect.selectedIndex = parseInt(this.dataset.index);
                hiddenSelect.dispatchEvent(new Event('change'));
                var thumbHtml = art.img ? '<img class="trigger-thumb" src="' + art.img + '" alt="">' : '';
                trigger.innerHTML = thumbHtml + art.name;
                trigger.classList.add('has-value');
                dropdown.querySelectorAll('.artwork-option').forEach(function(o) { o.classList.remove('selected'); });
                this.classList.add('selected');
                wrap.classList.remove('open');
                var fg = wrap.closest('.field-group');
                if (fg) fg.classList.remove('error');
            });
            dropdown.appendChild(div);
        });

        trigger.addEventListener('click', function(e) {
            e.preventDefault();
            document.querySelectorAll('.artwork-select-wrap.open').forEach(function(o) { if (o !== wrap) o.classList.remove('open'); });
            wrap.classList.toggle('open');
        });
    });

    document.addEventListener('click', function(e) {
        if (!e.target.closest('.artwork-select-wrap'))
            document.querySelectorAll('.artwork-select-wrap.open').forEach(function(w) { w.classList.remove('open'); });
    });

    /* ========================================
       TOP BAR SCROLL
    ======================================== */
    window.addEventListener('scroll', function() {
        document.getElementById('topBar').classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    /* ========================================
       HERO SLIDER
    ======================================== */
    var slides = document.querySelectorAll('.hero-slide');
    var dots = document.querySelectorAll('#heroDots .dot');
    var caption = document.getElementById('heroCaption');
    var cur = 0, interval;

    function goTo(i) {
        slides[cur].classList.remove('active');
        dots[cur].classList.remove('active');
        cur = i;
        slides[cur].classList.add('active');
        dots[cur].classList.add('active');
        caption.innerHTML = slides[cur].dataset.caption;
    }
    function next() { goTo((cur + 1) % slides.length); }
    function start() { interval = setInterval(next, 4000); }

    dots.forEach(function(d) {
        d.addEventListener('click', function() {
            clearInterval(interval); goTo(parseInt(this.dataset.index)); start();
        });
    });
    start();

    /* ========================================
       GALLERY DRAG
    ======================================== */
    var gt = document.getElementById('galleryTrack');
    var isDown = false, startX, sl;
    gt.addEventListener('mousedown', function(e) { isDown = true; gt.style.cursor = 'grabbing'; startX = e.pageX - gt.offsetLeft; sl = gt.scrollLeft; });
    gt.addEventListener('mouseleave', function() { isDown = false; gt.style.cursor = 'grab'; });
    gt.addEventListener('mouseup', function() { isDown = false; gt.style.cursor = 'grab'; });
    gt.addEventListener('mousemove', function(e) { if (!isDown) return; e.preventDefault(); gt.scrollLeft = sl - (e.pageX - gt.offsetLeft - startX) * 1.5; });
    document.getElementById('galleryPrev').addEventListener('click', function() { gt.scrollBy({ left: -360, behavior: 'smooth' }); });
    document.getElementById('galleryNext').addEventListener('click', function() { gt.scrollBy({ left: 360, behavior: 'smooth' }); });

    /* ========================================
       SELECT CHANGE COLOR
    ======================================== */
    document.querySelectorAll('.inquiry-form select').forEach(function(s) {
        s.addEventListener('change', function() { this.classList.toggle('has-value', !!this.value); });
    });

    /* ========================================
       FORM VALIDATION
    ======================================== */
    function validate(form) {
        var ok = true;
        form.querySelectorAll('.field-group').forEach(function(g) {
            var inp = g.querySelector('input[type="text"], input[type="email"], input[type="tel"], select, textarea');
            g.classList.remove('error');
            if (!inp || !inp.required) return;
            if (inp.tagName === 'SELECT') { if (!inp.value) { g.classList.add('error'); ok = false; } }
            else if (inp.type === 'email') { if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(inp.value.trim())) { g.classList.add('error'); ok = false; } }
            else { if (!inp.value.trim()) { g.classList.add('error'); ok = false; } }
        });
        return ok;
    }

    /* ========================================
       FORM SUBMISSION (Google Sheets + Tracking)
    ======================================== */
    var isSubmitting = false;

    document.getElementById('mainForm').addEventListener('submit', function(e) {
        e.preventDefault();
        if (isSubmitting) return; /* prevent double submit */
        if (!validate(this)) return;

        var form = this;
        var btn = form.querySelector('.btn-submit');
        var errorEl = document.getElementById('formError');

        /* Show loading state */
        isSubmitting = true;
        btn.classList.add('loading');
        errorEl.classList.remove('show');

        submitToSheets(form, function(err, payload) {
            if (err) {
                /* Error state */
                btn.classList.remove('loading');
                isSubmitting = false;
                errorEl.classList.add('show');
                return;
            }

            /* Success: hide form, show success message */
            form.style.display = 'none';
            document.getElementById('formSuccess').style.display = 'block';
            isSubmitting = false;

            /* Fire tracking events AFTER successful submission */
            fireLeadEvents(
                payload.artwork,
                payload.form_location,
                payload.budget
            );
        });
    });

    document.querySelectorAll('.inquiry-form input, .inquiry-form select, .inquiry-form textarea').forEach(function(el) {
        el.addEventListener('input', function() {
            var fg = this.closest('.field-group');
            if (fg) fg.classList.remove('error');
        });
        el.addEventListener('change', function() {
            var fg = this.closest('.field-group');
            if (fg) fg.classList.remove('error');
        });
    });

    /* ========================================
       ACCORDION
    ======================================== */
    document.querySelectorAll('.accordion-header').forEach(function(h) {
        h.addEventListener('click', function() {
            var item = this.parentElement, body = item.querySelector('.accordion-body'), open = item.classList.contains('open');
            document.querySelectorAll('.accordion-item').forEach(function(a) { a.classList.remove('open'); a.querySelector('.accordion-body').style.maxHeight = null; });
            if (!open) { item.classList.add('open'); body.style.maxHeight = body.scrollHeight + 'px'; }
        });
    });

    /* ========================================
       FADE-IN OBSERVER
    ======================================== */
    var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in').forEach(function(el) { obs.observe(el); });

    /* ========================================
       SMOOTH SCROLL FOR ANCHOR LINKS
    ======================================== */
    document.querySelectorAll('a[href^="#"]').forEach(function(a) {
        a.addEventListener('click', function(e) {
            var t = document.querySelector(this.getAttribute('href'));
            if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        });
    });

    /* ========================================
       MOBILE STICKY CTA
    ======================================== */
    var mobileCta = document.getElementById('mobileCta');
    var stickyBtn = mobileCta ? mobileCta.querySelector('.sticky-btn') : null;
    var formSection = document.getElementById('inquiry-form');

    if (stickyBtn && formSection) {
        stickyBtn.addEventListener('click', function() {
            formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });

        /* Hide when near the form section */
        var formObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                mobileCta.classList.toggle('hidden', entry.isIntersecting);
            });
        }, { rootMargin: '200px 0px 200px 0px', threshold: 0 });
        formObserver.observe(formSection);
    }

})();
</script>
</body>
</html>